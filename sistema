<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Atletas - Taekwondo</title>
    <style>
        :root {
            --primary-color: #0b1a30;    /* Azul Marinho Escuro (Liga) */
            --accent-color: #d63031;     /* Vermelho Vivo (Team Amazonas) */
            --bg-color: #f4f6f7;
            --card-bg: #ffffff;
            --text-color: #2c3e50;
            --border-color: #dcdde1;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            min-height: 100vh;
            padding: 40px 20px;
        }

        .container, .section-view {
            background-color: var(--card-bg);
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
            width: 100%;
            max-width: 850px;
            margin-bottom: 30px;
        }

        /* --- CABEÇALHO TELA PRINCIPAL --- */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 30px;
            padding: 25px 20px;
            border-radius: 8px;
            background: linear-gradient(135deg, #cfd8dc 0%, #eceff1 100%); 
            border-bottom: 4px solid var(--primary-color); 
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .header-logo {
            width: 95px;
            height: 95px;
            object-fit: contain;
            filter: drop-shadow(0px 3px 6px rgba(0, 0, 0, 0.12));
            flex-shrink: 0;
        }

        .header-text {
            text-align: center;
            flex: 1;
            min-width: 0;
        }

        .header h1 {
            font-size: clamp(18px, 2.8vw, 26px); 
            color: var(--primary-color);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            line-height: 1.2;
            font-weight: 800;
            white-space: nowrap;
        }

        .header p {
            font-size: 14px;
            color: var(--accent-color);
            margin-top: 6px;
            letter-spacing: 2px;
            font-weight: 700;
        }

        fieldset {
            border: none;
            margin-bottom: 25px;
        }

        legend {
            font-weight: bold;
            color: var(--primary-color);
            margin-bottom: 15px;
            text-transform: uppercase;
            font-size: 14px;
            letter-spacing: 0.5px;
        }

        .form-group { margin-bottom: 15px; }
        .form-row { display: flex; gap: 20px; }
        .form-row .form-group { flex: 1; }

        label {
            display: block;
            margin-bottom: 6px;
            font-size: 14px;
            font-weight: 500;
        }

        input[type="text"], input[type="date"], select {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            font-size: 15px;
            transition: all 0.3s ease;
            background-color: #fafafa;
        }

        input:focus, select:focus {
            border-color: var(--accent-color);
            outline: none;
            box-shadow: 0 0 0 3px rgba(214, 48, 49, 0.15);
        }

        .foto-3x4-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .preview-3x4 {
            width: 120px;
            height: 160px;
            border: 2px dashed var(--border-color);
            border-radius: 6px;
            background-color: #fdfefe;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .preview-3x4:hover {
            border-color: var(--accent-color);
            background-color: #fff;
        }

        .preview-3x4 img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

        .preview-3x4 .placeholder-text {
            text-align: center;
            font-size: 11px;
            color: #7f8c8d;
            padding: 10px;
        }

        .preview-3x4 .placeholder-text svg {
            width: 32px;
            height: 32px;
            fill: #95a5a6;
            margin-bottom: 8px;
        }

        input[type="file"] { display: none; }

        .btn-submit {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 14px 20px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
            transition: all 0.2s ease;
            text-transform: uppercase;
        }

        .btn-submit:hover { background-color: #122846; border-bottom: 3px solid var(--accent-color); }
        .btn-submit.modo-edicao { background-color: #2980b9; }

        /* --- ESTILOS DA TABELA --- */
        .section-view-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-left: 4px solid var(--accent-color);
            padding-left: 10px;
        }

        .section-view h2 { font-size: 18px; color: var(--primary-color); text-transform: uppercase; }

        .badge-total-filiados {
            background-color: var(--primary-color);
            color: white;
            font-size: 14px;
            font-weight: bold;
            padding: 6px 14px;
            border-radius: 20px;
            border-bottom: 2px solid var(--accent-color);
        }

        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; text-align: left; font-size: 14px; }
        th, td { padding: 12px 15px; border-bottom: 1px solid var(--border-color); vertical-align: middle; }
        th { background-color: #f8f9fa; color: var(--primary-color); font-weight: 600; }
        
        .atleta-info { display: flex; align-items: center; gap: 12px; }
        .atleta-foto-mini { width: 35px; height: 45px; border-radius: 4px; object-fit: cover; border: 1px solid var(--border-color); }
        
        .badge-inscricao {
            background-color: #7f8c8d;
            color: white;
            padding: 3px 6px;
            border-radius: 4px;
            font-family: monospace;
            font-size: 12px;
            font-weight: bold;
        }

        .acoes-container { display: flex; gap: 10px; flex-wrap: wrap; }

        .btn-acao {
            background: none;
            border: none;
            font-weight: bold;
            cursor: pointer;
            text-decoration: underline;
            font-size: 13px;
        }
        .btn-ver-perfil { color: #2980b9; }
        .btn-editar { color: #27ae60; }
        .btn-carteirinha { color: #e67e22; }
        .btn-excluir { color: #c0392b; }

        .badge-faixa {
            background-color: var(--accent-color);
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            display: inline-block;
        }

        .sem-dados { text-align: center; color: #95a5a6; padding: 20px; }

        /* --- MODAIS COMPARTILHADOS --- */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0, 0, 0, 0.6);
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0; pointer-events: none;
            transition: opacity 0.3s ease;
            z-index: 1000;
        }

        .modal-overlay.active { opacity: 1; pointer-events: auto; }
        .modal-card {
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            width: 90%;
            max-width: 420px;
            text-align: center;
            position: relative;
            transform: scale(0.8);
            transition: transform 0.3s ease;
            z-index: 1010;
        }
        .modal-overlay.active .modal-card { transform: scale(1); }
        .modal-close {
            position: absolute;
            top: 15px; right: 15px;
            background: #eee; border: none;
            width: 30px; height: 30px; border-radius: 50%;
            font-weight: bold; cursor: pointer;
            z-index: 10;
        }

        /* --- MODAL DE PERFIL TRADICIONAL --- */
        .modal-foto-3x4 {
            width: 130px;
            height: 170px;
            object-fit: cover;
            border: 3px solid var(--primary-color);
            border-radius: 6px;
            margin: 0 auto 20px auto;
        }
        .modal-nome { font-size: 20px; color: var(--primary-color); margin-bottom: 15px; }
        .modal-info-linha { text-align: left; padding: 8px 0; border-bottom: 1px dashed #eee; font-size: 14px; }
        .modal-info-linha strong { color: #7f8c8d; font-weight: 500; }

        /* --- CARTEIRINHA DIGITAL --- */
        .carteirinha-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
            align-items: center;
            margin-top: 15px;
        }

        .carteirinha-face {
            width: 340px;
            height: 230px;
            border-radius: 14px;
            background: #ffffff;
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            position: relative;
            overflow: hidden;
            border: 1px solid #ccc;
            text-align: left;
        }

        .cc-header {
            background: linear-gradient(135deg, #cfd8dc 0%, #eceff1 100%);
            border-bottom: 3px solid var(--primary-color);
            padding: 8px 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 6px;
        }
        
        .cc-header-logo {
            width: 32px;
            height: 32px;
            object-fit: contain;
            filter: drop-shadow(0px 1px 3px rgba(0,0,0,0.12));
            flex-shrink: 0;
        }

        .cc-header-text-container {
            text-align: center;
            flex: 1;
        }

        .cc-header-title { 
            font-size: 9px; 
            font-weight: 800; 
            color: var(--primary-color); 
            letter-spacing: 0.3px; 
            line-height: 1.2; 
        }
        
        .cc-header-sub { 
            font-size: 7.5px; 
            color: var(--accent-color); 
            font-weight: 700; 
            letter-spacing: 1px;
        }

        .cc-body-frente { 
            display: flex; 
            padding: 12px; 
            gap: 14px; 
            height: calc(100% - 51px); 
            background: #fafafa; 
        }
        
        .cc-foto { 
            width: 90px; 
            height: 115px; 
            object-fit: cover; 
            border: 2px solid var(--primary-color); 
            border-radius: 4px; 
            background: #eee; 
            flex-shrink: 0;
        }
        
        .cc-detalhes { 
            flex: 1; 
            display: flex; 
            flex-direction: column; 
            justify-content: flex-start;
            gap: 8px; 
            overflow: hidden;
        }
        
        .cc-label { font-size: 8px; color: #7f8c8d; text-transform: uppercase; font-weight: 600; margin-bottom: 1px; }
        
        .cc-valor-nome { 
            font-size: 12px; 
            color: #0b1a30; 
            text-transform: uppercase; 
            font-weight: bold;
            line-height: 1.3;
            max-height: 34px;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2; 
            -webkit-box-orient: vertical;
        }

        .cc-valor-reg {
            font-size: 13px; 
            color: var(--accent-color); 
            font-weight: 800; 
            font-family: monospace;
        }

        .cc-footer-faixa {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            background-color: #2c3e50;
            color: white;
            text-align: center;
            font-size: 10px;
            font-weight: 800;
            padding: 6px 45px 6px 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: background 0.3s ease;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.4);
        }

        /* --- VERSO (SEM QRCODE E COM ESPAÇO AMPLIADO) --- */
        .cc-body-verso {
            padding: 16px 14px;
            height: 100%;
            background: #fdfefe;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .cc-verso-conteudo {
            display: flex;
            height: calc(100% - 35px);
            width: 100%;
        }

        .cc-verso-grid { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 12px 10px; 
            flex: 1;
            width: 100%;
        }

        .cc-valor-verso { font-size: 11px; color: #2c3e50; font-weight: 700; }
        
        .cc-assinatura-area {
            text-align: center;
            border-top: 1px dashed #bdc3c7;
            padding-top: 5px;
        }
        .cc-assinatura-linha { font-family: 'Courier New', monospace; font-size: 9px; color: #7f8c8d; font-style: italic; }
        .cc-chancela { font-size: 8px; color: #95a5a6; text-transform: uppercase; font-weight: bold; margin-top: 1px; }

        @media (max-width: 768px) { 
            .form-row { flex-direction: column; gap: 0; } 
            .header { flex-direction: column; text-align: center; gap: 15px; padding: 25px 15px; border-bottom: none; border-right: 4px solid var(--primary-color); }
            .header-text { text-align: center; order: 2; }
            .header-logo:first-child { order: 1; }
            .header-logo:last-child { order: 3; }
            .header h1 { font-size: clamp(16px, 4.5vw, 22px); }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <img src="team.png" alt="Logo Team Amazonas" class="header-logo">
        <div class="header-text">
            <h1>TEAM AMAZONAS TAEKWONDO LIGA</h1>
            <p>CADASTRO DE FILIADOS</p>
        </div>
        <img src="liga1.png" alt="Logo Liga Nacional" class="header-logo">
    </div>

    <form id="formAtleta">
        <fieldset>
            <legend>Dados Pessoais e Foto</legend>
            <div class="form-row">
                <div style="flex: 3; display: flex; flex-direction: column; justify-content: space-between;">
                    <div class="form-group">
                        <label for="nome">Nome Completo</label>
                        <input type="text" id="nome" required placeholder="Ex: Carlos Silva">
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="nascimento">Data de Nascimento</label>
                            <input type="date" id="nascimento" required>
                        </div>
                        <div class="form-group">
                            <label for="cpf">CPF</label>
                            <input type="text" id="cpf" required placeholder="000.000.000-00" maxlength="14">
                        </div>
                    </div>
                </div>

                <div class="form-group foto-3x4-container" style="flex: 1; min-width: 140px;">
                    <label>Foto 3x4</label>
                    <div class="preview-3x4" onclick="document.getElementById('foto').click()">
                        <div class="placeholder-text" id="placeholderText">
                            <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54-1.96-2.36L6.5(17)h11l-3.54-4.71z"/></svg>
                            <br>Clique para incluir
                        </div>
                        <img id="imgPreview" src="" alt="Preview">
                    </div>
                    <input type="file" id="foto" accept="image/*">
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Graduação e Afiliação</legend>
            <div class="form-row">
                <div class="form-group">
                    <label for="graduacao">Graduação Atual</label>
                    <select id="graduacao" required>
                        <option value="" disabled selected>Selecione a faixa...</option>
                        <optgroup label="Gubs (Faixas Coloridas)">
                            <option value="10º Gub - Branca">10º Gub - Branca</option>
                            <option value="9º Gub - Branca Ponta Amarela">9º Gub - Branca Ponta Amarela</option>
                            <option value="8º Gub - Amarela">8º Gub - Amarela</option>
                            <option value="7º Gub - Amarela Ponta Verde">7º Gub - Amarela Ponta Verde</option>
                            <option value="6º Gub - Verde">6º Gub - Verde</option>
                            <option value="5º Gub - Verde Ponta Azul">5º Gub - Verde Ponta Azul</option>
                            <option value="4º Gub - Azul">4º Gub - Azul</option>
                            <option value="3º Gub - Azul Ponta Vermelha">3º Gub - Azul Ponta Vermelha</option>
                            <option value="2º Gub - Vermelha">2º Gub - Vermelha</option>
                            <option value="1º Gub - Vermelha Ponta Preta">1º Gub - Vermelha Ponta Preta</option>
                        </optgroup>
                        <optgroup label="Dans (Faixas Pretas)">
                            <option value="1º Dan - Preta">1º Dan - Faixa Preta</option>
                            <option value="2º Dan - Preta">2º Dan - Faixa Preta</option>
                            <option value="3º Dan - Preta">3º Dan - Faixa Preta</option>
                            <option value="4º Dan - Mestre">4º Dan - Mestre</option>
                        </optgroup>
                    </select>
                </div>
                <div class="form-group">
                    <label for="dojang">Academia / Dojang</label>
                    <input type="text" id="dojang" required placeholder="Ex: Associação Central">
                </div>
                <div class="form-group">
                    <label for="mestre">Professor / Mestre</label>
                    <input type="text" id="mestre" required placeholder="Ex: Mestre Jung">
                </div>
            </div>
        </fieldset>

        <button type="submit" id="btnSalvar" class="btn-submit">Salvar Atleta</button>
    </form>
</div>

<div class="section-view">
    <div class="section-view-header">
        <h2>Filiados Cadastrados</h2>
        <div class="badge-total-filiados" id="totalFiliados">Total: 0</div>
    </div>
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Nº Inscrição</th>
                    <th>Atleta</th>
                    <th>Academia</th>
                    <th>Graduação</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody id="tabelaAtletas">
                <tr id="linhaVazia">
                    <td colspan="5" class="sem-dados">Nenhum filiado cadastrado até o momento.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="modalPerfil" onclick="fecharModalAoClicarFora(event, 'modalPerfil')">
    <div class="modal-card">
        <button class="modal-close" onclick="fecharModal('modalPerfil')">X</button>
        <img src="" id="modalFoto" class="modal-foto-3x4" alt="Foto do Atleta">
        <h3 id="modalNome" class="modal-nome">Nome do Atleta</h3>
        <div class="modal-info-linha"><strong>Nº Inscrição:</strong> <span id="modalInscricao" style="font-weight: bold; color: var(--accent-color);"></span></div>
        <div class="modal-info-linha"><strong>CPF:</strong> <span id="modalCPF"></span></div>
        <div class="modal-info-linha"><strong>Nascimento:</strong> <span id="modalNasc"></span></div>
        <div class="modal-info-linha"><strong>Academia:</strong> <span id="modalDojang"></span></div>
        <div class="modal-info-linha"><strong>Mestre:</strong> <span id="modalMestre"></span></div>
        <div class="modal-info-linha"><strong>Graduação:</strong> <span id="modalFaixa" class="badge-faixa"></span></div>
    </div>
</div>

<div class="modal-overlay" id="modalCarteirinha" onclick="fecharModalAoClicarFora(event, 'modalCarteirinha')">
    <div class="modal-card" style="max-width: 460px; background-color: #f0f3f4;">
        <button class="modal-close" onclick="fecharModal('modalCarteirinha')">X</button>
        <h3 style="color: var(--primary-color); margin-bottom: 5px; font-size: 18px;">Carteirinha Digital</h3>
        <p style="font-size: 12px; color: #7f8c8d; margin-bottom: 15px;">Documento de identificação oficial interno</p>
        
        <div class="carteirinha-container">
            <div class="carteirinha-face">
                <div class="cc-header">
                    <img src="team.png" alt="Logo Team" class="cc-header-logo">
                    <div class="cc-header-text-container">
                        <div class="cc-header-title">TEAM AMAZONAS TAEKWONDO LIGA</div>
                        <div class="cc-header-sub">FILIADO OFICIAL</div>
                    </div>
                    <img src="liga1.png" alt="Logo Liga" class="cc-header-logo">
                </div>
                <div class="cc-body-frente">
                    <img src="" id="ccFoto" class="cc-foto" alt="Foto Atleta">
                    <div class="cc-detalhes">
                        <div>
                            <div class="cc-label">Nome do Filiado</div>
                            <div class="cc-valor-nome" id="ccNome">NOME COMPLETO DO ATLETA</div>
                        </div>
                        <div>
                            <div class="cc-label">Nº Registro</div>
                            <div class="cc-valor-reg" id="ccInscricao">2026-000</div>
                        </div>
                        <div>
                            <div class="cc-label">Validade</div>
                            <div class="cc-valor-reg" id="ccValidade" style="color: #27ae60;">00/00/0000</div>
                        </div>
                    </div>
                </div>
                <div class="cc-footer-faixa" id="ccFaixa">FAIXA COMPLETA</div>
            </div>

            <div class="carteirinha-face">
                <div class="cc-body-verso">
                    <div class="cc-verso-conteudo">
                        <div class="cc-verso-grid">
                            <div>
                                <div class="cc-label">CPF</div>
                                <div class="cc-valor-verso" id="ccCpf">000.000.000-00</div>
                            </div>
                            <div>
                                <div class="cc-label">Nascimento</div>
                                <div class="cc-valor-verso" id="ccNasc">01/01/2000</div>
                            </div>
                            <div style="grid-column: span 2;">
                                <div class="cc-label">Organização / Dojang</div>
                                <div class="cc-valor-verso" id="ccDojang">Nome da Academia</div>
                            </div>
                            <div style="grid-column: span 2;">
                                <div class="cc-label">Mestre / Instrutor</div>
                                <div class="cc-valor-verso" id="ccMestre">Nome do Mestre</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="cc-assinatura-area">
                        <div class="cc-assinatura-linha">Team Amazonas Liga Digital</div>
                        <div class="cc-chancela">Chancela Eletrônica da Presidência</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let listaAtletas = JSON.parse(localStorage.getItem('listaAtletas')) || [];
    let contadorInscricao = parseInt(localStorage.getItem('contadorInscricao')) || 1; 
    let idAtletaEmEdicao = null; 
    const fotoPadrao = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 3 4' fill='%23ccc'><rect width='3' height='4' fill='%23eee'/><circle cx='1.5' cy='1.5' r='0.6'/><path d='M0.5 3.5 c0 -0.8 0.5 -1.2 1 -1.2 s1 0.4 1 1.2'/></svg>";

    document.addEventListener("DOMContentLoaded", atualizarTabela);

    // Máscara de CPF
    document.getElementById('cpf').addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, "");
        if (value.length > 11) value = value.slice(0, 11);
        value = value.replace(/(\d{3})(\d)/, "$1.$2");
        value = value.replace(/(\d{3})(\d)/, "$1.$2");
        value = value.replace(/(\d{3})(\d{1,2})$/, "$1-$2");
        e.target.value = value;
    });

    document.getElementById('foto').addEventListener('change', function(e) {
        const input = e.target;
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) { exibirPreviewFoto(e.target.result); };
            reader.readAsDataURL(input.files[0]);
        }
    });

    function exibirPreviewFoto(src) {
        const imgElement = document.getElementById('imgPreview');
        const placeholder = document.getElementById('placeholderText');
        imgElement.src = src;
        imgElement.style.display = 'block';
        placeholder.style.display = 'none';
    }

    function resetarPreviewFoto() {
        const imgPreview = document.getElementById('imgPreview');
        imgPreview.style.display = 'none';
        imgPreview.src = '';
        document.getElementById('placeholderText').style.display = 'block';
    }

    function calcularValidade() {
        const data = new Date();
        data.setFullYear(data.getFullYear() + 1);
        return data.toLocaleDateString('pt-BR');
    }

    document.getElementById('formAtleta').addEventListener('submit', function(event) {
        event.preventDefault();
        const imgPreview = document.getElementById('imgPreview');
        const fotoAtleta = (imgPreview.style.display === 'block' && imgPreview.src) ? imgPreview.src : fotoPadrao;
        const dataFormatada = document.getElementById('nascimento').value.split('-').reverse().join('/');

        if (idAtletaEmEdicao !== null) {
            const index = listaAtletas.findIndex(a => a.id === idAtletaEmEdicao);
            if (index !== -1) {
                listaAtletas[index].nome = document.getElementById('nome').value;
                listaAtletas[index].cpf = document.getElementById('cpf').value;
                listaAtletas[index].nascimento = dataFormatada;
                listaAtletas[index].graduacao = document.getElementById('graduacao').value;
                listaAtletas[index].dojang = document.getElementById('dojang').value;
                listaAtletas[index].mestre = document.getElementById('mestre').value;
                listaAtletas[index].foto = fotoAtleta;
                
                if(!listaAtletas[index].validade) {
                    listaAtletas[index].validade = calcularValidade();
                }
                
                idAtletaEmEdicao = null;
                const btnSalvar = document.getElementById('btnSalvar');
                btnSalvar.innerText = "Salvar Atleta";
                btnSalvar.style.backgroundColor = "var(--primary-color)";
            }
        } else {
            const anoAtual = new Date().getFullYear();
            const numeroInscricaoFormatado = `${anoAtual}-${String(contadorInscricao).padStart(3, '0')}`;

            const atleta = {
                id: Date.now(),
                inscricao: numeroInscricaoFormatado,
                nome: document.getElementById('nome').value,
                cpf: document.getElementById('cpf').value,
                nascimento: dataFormatada,
                graduacao: document.getElementById('graduacao').value,
                dojang: document.getElementById('dojang').value,
                mestre: document.getElementById('mestre').value,
                foto: fotoAtleta,
                validade: calcularValidade()
            };
            listaAtletas.push(atleta);
            contadorInscricao++;
        }

        salvarDados();
        atualizarTabela();
        document.getElementById('formAtleta').reset();
        resetarPreviewFoto();
    });

    function atualizarTabela() {
        const tabela = document.getElementById('tabelaAtletas');
        const badgeTotal = document.getElementById('totalFiliados');
        tabela.innerHTML = '';
        badgeTotal.innerText = `Total: ${listaAtletas.length}`;

        if (listaAtletas.length === 0) {
            tabela.innerHTML = `<tr><td colspan="5" class="sem-dados">Nenhum filiado cadastrado até o momento.</td></tr>`;
            return;
        }

        listaAtletas.forEach(atleta => {
            const novaLinha = document.createElement('tr');
            novaLinha.innerHTML = `
                <td><span class="badge-inscricao">${atleta.inscricao}</span></td>
                <td>
                    <div class="atleta-info">
                        <img src="${atleta.foto}" class="atleta-foto-mini" alt="3x4">
                        <strong>${atleta.nome}</strong>
                    </div>
                </td>
                <td>${atleta.dojang}</td>
                <td><span class="badge-faixa">${atleta.graduacao}</span></td>
                <td>
                    <div class="acoes-container">
                        <button class="btn-acao btn-ver-perfil" onclick="abrirPerfil(${atleta.id})">Ver Perfil</button>
                        <button class="btn-acao btn-editar" onclick="carregarEdicao(${atleta.id})">Editar</button>
                        <button class="btn-acao btn-carteirinha" onclick="abrirCarteirinha(${atleta.id})">Carteirinha</button>
                        <button class="btn-acao btn-excluir" onclick="deletarAtleta(${atleta.id})">Excluir</button>
                    </div>
                </td>
            `;
            tabela.appendChild(novaLinha);
        });
    }

    function carregarEdicao(id) {
        const atleta = listaAtletas.find(a => a.id === id);
        if (!atleta) return;
        idAtletaEmEdicao = atleta.id;

        document.getElementById('nome').value = atleta.nome;
        document.getElementById('cpf').value = atleta.cpf;
        document.getElementById('dojang').value = atleta.dojang;
        document.getElementById('mestre').value = atleta.mestre;
        document.getElementById('graduacao').value = atleta.graduacao;

        if(atleta.nascimento) {
            const partesData = atleta.nascimento.split('/');
            if(partesData.length === 3) document.getElementById('nascimento').value = `${partesData[2]}-${partesData[1]}-${partesData[0]}`;
        }

        if (atleta.foto && atleta.foto !== fotoPadrao) exibirPreviewFoto(atleta.foto);
        else resetarPreviewFoto();

        const btnSalvar = document.getElementById('btnSalvar');
        btnSalvar.innerText = "Atualizar Cadastro";
        btnSalvar.style.backgroundColor = "#2980b9";
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function deletarAtleta(id) {
        if (confirm("Tem certeza que deseja excluir permanentemente este filiado?")) {
            listaAtletas = listaAtletas.filter(a => a.id !== id);
            salvarDados();
            atualizarTabela();
        }
    }

    function salvarDados() {
        localStorage.setItem('listaAtletas', JSON.stringify(listaAtletas));
        localStorage.setItem('contadorInscricao', contadorInscricao.toString());
    }

    function abrirPerfil(id) {
        const atleta = listaAtletas.find(a => a.id === id);
        if(!atleta) return;

        document.getElementById('modalFoto').src = atleta.foto;
        document.getElementById('modalNome').innerText = atleta.nome;
        document.getElementById('modalInscricao').innerText = atleta.inscricao;
        document.getElementById('modalCPF').innerText = atleta.cpf;
        document.getElementById('modalNasc').innerText = atleta.nascimento;
        document.getElementById('modalDojang').innerText = atleta.dojang;
        document.getElementById('modalMestre').innerText = atleta.mestre;
        document.getElementById('modalFaixa').innerText = atleta.graduacao;

        document.getElementById('modalPerfil').classList.add('active');
    }

    function abrirCarteirinha(id) {
        const atleta = listaAtletas.find(a => a.id === id);
        if(!atleta) return;

        document.getElementById('ccFoto').src = atleta.foto;
        document.getElementById('ccNome').innerText = atleta.nome;
        document.getElementById('ccInscricao').innerText = atleta.inscricao;
        document.getElementById('ccValidade').innerText = atleta.validade ? atleta.validade : calcularValidade();
        document.getElementById('ccFaixa').innerText = atleta.graduacao;
        document.getElementById('ccCpf').innerText = atleta.cpf;
        document.getElementById('ccNasc').innerText = atleta.nascimento;
        document.getElementById('ccDojang').innerText = atleta.dojang;
        document.getElementById('ccMestre').innerText = atleta.mestre;

        const painelFaixa = document.getElementById('ccFaixa');
        const faixa = atleta.graduacao;

        const coresHex = {
            "Branca": "#ffffff",
            "Amarela": "#f1c40f",
            "Verde": "#27ae60",
            "Azul": "#2980b9",
            "Vermelha": "#c0392b",
            "Preta": "#000000",
            "Mestre": "#000000"
        };

        let corBase = "#2c3e50"; 
        let corPonta = null;
        let corTexto = "#ffffff";

        if (faixa.includes("Branca")) { corBase = coresHex["Branca"]; corTexto = "#2c3e50"; }
        else if (faixa.includes("Amarela")) { corBase = coresHex["Amarela"]; corTexto = "#000000"; }
        else if (faixa.includes("Verde")) { corBase = coresHex["Verde"]; }
        else if (faixa.includes("Azul")) { corBase = coresHex["Azul"]; }
        else if (faixa.includes("Vermelha")) { corBase = coresHex["Vermelha"]; }
        else if (faixa.includes("Preta") || faixa.includes("Mestre")) { corBase = coresHex["Preta"]; corTexto = "#f1c40f"; }

        if (faixa.includes("Ponta")) {
            if (faixa.includes("Ponta Amarela")) corPonta = coresHex["Amarela"];
            else if (faixa.includes("Ponta Verde")) corPonta = coresHex["Verde"];
            else if (faixa.includes("Ponta Azul")) corPonta = coresHex["Azul"];
            else if (faixa.includes("Ponta Vermelha")) corPonta = coresHex["Vermelha"];
            else if (faixa.includes("Ponta Preta")) corPonta = coresHex["Preta"];
        }

        painelFaixa.style.color = corTexto;

        if (corPonta) {
            painelFaixa.style.background = `linear-gradient(to right, ${corBase} 0%, ${corBase} 75%, ${corPonta} 75%, ${corPonta} 100%)`;
        } else {
            painelFaixa.style.background = corBase;
        }

        if (faixa.includes("10º Gub") || faixa.includes("Branca Ponta Amarela")) {
            painelFaixa.style.borderTop = "1px solid #bdc3c7";
        } else {
            painelFaixa.style.borderTop = "none";
        }

        document.getElementById('modalCarteirinha').classList.add('active');
    }

    function fecharModal(idModal) {
        document.getElementById(idModal).classList.remove('active');
    }

    function fecharModalAoClicarFora(event, idModal) {
        if (event.target.id === idModal) {
            fecharModal(idModal);
        }
    }
</script>

</body>
</html>
